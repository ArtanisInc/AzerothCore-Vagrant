# -*- mode: ruby -*-
# vi: set ft=ruby :

# Load environment variables from .env file
if File.exist?(".env")
  File.readlines(".env").each do |line|
    next if line.strip.start_with?("#") || line.strip.empty?
    values = line.split("=")
    ENV[values[0].strip] = values[1].strip if values.length == 2
  end
end

Vagrant.configure("2") do |config|
  # Base configuration - Ubuntu 22.04 LTS
  config.vm.box = "bento/ubuntu-22.04"
  config.vm.hostname = "azerothcore"
  config.vm.disk :disk, size: (ENV['VM_DISK_SIZE'] || "80GB"), primary: true

  # Network configuration
  # Port forwarding for authserver (3724) and worldserver (8085)
  config.vm.network "forwarded_port", guest: 3724, host: 3724, protocol: "tcp"
  config.vm.network "forwarded_port", guest: 8085, host: 8085, protocol: "tcp"

  # Private network for direct access (optional, uncomment if needed)
  # config.vm.network "private_network", ip: "192.168.56.10"

  # VM resource configuration
  config.vm.provider "virtualbox" do |vb|
    vb.name = (ENV['VM_NAME'] || "AzerothCore-Server-wow")
    vb.memory = (ENV['VM_RAM'] || 8192).to_i
    vb.cpus = (ENV['VM_CPUS'] || 4).to_i

    # Improve multi-core handling and stability
    vb.customize ["modifyvm", :id, "--ioapic", "on"]

    # Increase VRAM to avoid warnings
    vb.customize ["modifyvm", :id, "--vram", "16"]

    # Use the virtio network driver for better performance
    vb.customize ["modifyvm", :id, "--nictype1", "virtio"]

    # Fix slow DNS issues inside the VM
    vb.customize ["modifyvm", :id, "--natdnshostresolver1", "on"]
  end

  # Shared folder for client data files
  config.vm.synced_folder ".", "/vagrant"

  # Provisioning
  config.vm.provision "shell", path: "provision/setup.sh"
end
